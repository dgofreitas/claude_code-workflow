filters:
  and:
    - type == "checkpoint"
formulas:
  projeto: file.folder.split("/").slice(0, 1)
  cov: if(coverage, coverage + "%")
properties:
  formula.projeto:
    displayName: Projeto
  note.title:
    displayName: Título
  note.status:
    displayName: Status
  formula.cov:
    displayName: Cov
  note.epic:
    displayName: Épico
views:
  - type: table
    name: Story Board
    groupBy:
      property: development
      direction: ASC
    order:
      - formula.projeto
      - title
      - status
      - formula.cov
      - epic
